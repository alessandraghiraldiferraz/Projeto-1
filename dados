# Carrega os dados JSON
lista_atividades = json.loads(dados_atividades_json)

# Nome do arquivo do banco de dados SQLite
db_name = 'escola_atividades.db'

def criar_banco():
    # Conecta ao banco de dados (cria o arquivo se não existir)
    conn = sqlite3.connect(db_name)
    cursor = conn.cursor()

    # Cria a tabela de atividades dos alunos se ela não existir
    # Adicionamos uma coluna 'id' autoincrementável como chave primária para cada registro de atividade
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS atividades_alunos (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        aluno_id TEXT,
        aluno_nome TEXT,
        aluno_sobrenome TEXT,
        serie TEXT,
        turma TEXT,
        disciplina TEXT,
        nome_atividade TEXT,
        descricao_atividade TEXT,
        tipo_atividade TEXT,
        data_atividade TEXT
    )
    ''')

    # Insere os dados na tabela
    for atividade in lista_atividades:
        cursor.execute('''
        INSERT INTO atividades_alunos (
            aluno_id, aluno_nome, aluno_sobrenome, serie, turma, 
            disciplina, nome_atividade, descricao_atividade, 
            tipo_atividade, data_atividade
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (
            atividade.get('aluno_id'),
            atividade.get('aluno_nome'),
            atividade.get('aluno_sobrenome'),
            atividade.get('serie'),
            atividade.get('turma'),
            atividade.get('disciplina'),
            atividade.get('nome_atividade'),
            atividade.get('descricao_atividade'),
            atividade.get('tipo_atividade'),
            atividade.get('data_atividade')
        ))

    # Salva (commit) as mudanças e fecha a conexão
    conn.commit()
    conn.close()
    print(f"Banco de dados '{db_name}' criado e populado com sucesso!")

if __name__ == '__main__':
    criar_banco()
